# ─── Public app config ───────────────────────────────────────────────────────
# Canonical public URL. Used for self-referential API/IDE-integration links,
# OAuth redirect URLs, and Stripe return URLs.
APP_URL="https://repohive.cloud"

# Server port (defaults to 24678 if unset).
PORT="24678"

# ─── AI providers (server-side only — never exposed to the browser) ──────────
# DeepSeek powers repository analysis (categorisation, tags, summary, tiering).
DEEPSEEK_API_KEY=""

# Gemini powers vector embeddings used for semantic search / recommendations.
GEMINI_API_KEY=""

# ─── GitHub (server-side only) ───────────────────────────────────────────────
# Optional but strongly recommended — raises the API limit from 60 to 5000 req/hr.
GITHUB_TOKEN=""

# ─── Database: Turso / libSQL ────────────────────────────────────────────────
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN=""

# ─── Auth: Clerk ─────────────────────────────────────────────────────────────
# Publishable key is safe for the browser and must be prefixed for Vite.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
# Secret key is server-side only — never expose to the browser.
CLERK_SECRET_KEY="sk_test_..."

# ─── Admin ───────────────────────────────────────────────────────────────────
# Clerk user id(s) allowed to curate the preloaded App Killers library
# (comma-separated). Find yours in the Clerk dashboard or the server logs
# ("Fetching repos for <tenantId>"). With auth disabled (no CLERK_SECRET_KEY)
# the dev tenant is treated as admin.
ADMIN_USER_IDS=""

# ─── Billing: Stripe ─────────────────────────────────────────────────────────
# Secret key: Stripe dashboard → Developers → API keys.
STRIPE_SECRET_KEY="sk_test_..."
# Webhook signing secret: shown when you create the webhook endpoint
# (https://repohive.cloud/api/stripe/webhook).
STRIPE_WEBHOOK_SECRET="whsec_..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Price IDs from Stripe dashboard → Products. One recurring price per
# plan/interval (Solo $19/mo, $180/yr; Studio $49/mo, $468/yr).
STRIPE_PRICE_SOLO_MONTHLY="price_..."
STRIPE_PRICE_SOLO_ANNUAL="price_..."
STRIPE_PRICE_STUDIO_MONTHLY="price_..."
STRIPE_PRICE_STUDIO_ANNUAL="price_..."
