# ─── Public app config ───────────────────────────────────────────────────────
# Canonical public URL. Used for self-referential API/IDE-integration links,
# OAuth redirect URLs, and Stripe return URLs.
APP_URL="https://repohive.cloud"

# Server port (defaults to 24678 if unset).
PORT="24678"

# ─── AI providers (server-side only — never exposed to the browser) ──────────
# DeepSeek powers repository analysis (categorisation, tags, summary, tiering).
DEEPSEEK_API_KEY=""

# Gemini powers vector embeddings used for semantic search / recommendations.
GEMINI_API_KEY=""

# ─── GitHub (server-side only) ───────────────────────────────────────────────
# Optional but strongly recommended — raises the API limit from 60 to 5000 req/hr.
GITHUB_TOKEN=""

# ─── Database: Turso / libSQL ────────────────────────────────────────────────
TURSO_DATABASE_URL="libsql://your-db.turso.io"
TURSO_AUTH_TOKEN=""

# ─── Auth: Clerk ─────────────────────────────────────────────────────────────
# Publishable key is safe for the browser and must be prefixed for Vite.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_..."
# Secret key is server-side only — never expose to the browser.
CLERK_SECRET_KEY="sk_test_..."

# ─── Billing: Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
